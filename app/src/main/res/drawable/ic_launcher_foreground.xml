<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Ghost Pulse: A signal waveform suggesting "alive, monitoring, precise"
         Safe zone: 18-90 (72dp centered in 108dp)
         Baseline at y=62, peaks go upward -->

    <!-- Subtle baseline glow (wider, dimmer) -->
    <path
        android:fillColor="#00000000"
        android:pathData="M24,62 L84,62"
        android:strokeWidth="3"
        android:strokeColor="#0D00D4AA"
        android:strokeLineCap="round" />

    <!-- Main waveform path — 4 peaks, ascending then descending
         Peak 1: small (noise floor)
         Peak 2: medium (signal detected)
         Peak 3: TALL (primary signal — the detection moment)
         Peak 4: medium-small (signal fading)
         Connected by sharp angular lines, not curves -->
    <path
        android:fillColor="#00000000"
        android:pathData="M24,62 L32,62 L35,56 L38,62 L44,62 L47,48 L50,62 L55,62 L58,34 L61,62 L67,62 L70,52 L73,62 L84,62"
        android:strokeWidth="2.5"
        android:strokeColor="#00D4AA"
        android:strokeLineCap="round"
        android:strokeLineJoin="round" />

    <!-- Peak highlight dot — on the tallest peak (the "detection point") -->
    <path
        android:fillColor="#00D4AA"
        android:pathData="M58,33 m-2.5,0 a2.5,2.5 0 1,1 5,0 a2.5,2.5 0 1,1 -5,0" />

    <!-- Peak glow ring — subtle outer ring on the detection point -->
    <path
        android:fillColor="#00000000"
        android:pathData="M58,33 m-5,0 a5,5 0 1,1 10,0 a5,5 0 1,1 -10,0"
        android:strokeWidth="0.8"
        android:strokeColor="#3300D4AA" />

    <!-- "S" letterform below the waveform — small, precise, brand mark -->
    <path
        android:fillColor="#00000000"
        android:pathData="M48,72 C48,70 50,69 52,69 L56,69 C58,69 60,70 60,72 C60,74 58,75 56,75 L52,75 C50,75 48,76 48,78 C48,80 50,81 52,81 L56,81 C58,81 60,80 60,78"
        android:strokeWidth="1.5"
        android:strokeColor="#555568"
        android:strokeLineCap="round"
        android:strokeLineJoin="round" />

</vector>
